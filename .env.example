# Local development defaults. Copy this file to `.env` for host-run scripts.
# Docker Compose injects the same values into the API container.
DATABASE_URL=postgres://dahdit:dahdit@localhost:5432/dahdit
JWT_SECRET=dev-only-jwt-secret-min-32-chars-long-x
API_PORT=4000
WEB_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
